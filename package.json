{
  "name": "pi-codedb",
  "version": "1.0.2",
  "description": "Code intelligence for pi — structural indexing, trigram search, symbol lookup via codedb REST API. Inspired by Cloudflare Dynamic Workers: TypeScript types as compact API surface.",
  "keywords": [
    "pi-package"
  ],
  "license": "MIT",
  "type": "module",
  "scripts": {
    "lint": "oxlint",
    "fmt": "oxfmt --check .",
    "fmt:fix": "oxfmt .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:contract": "vitest run extensions/pi-codedb/contract.test.ts",
    "check": "oxlint && oxfmt --check . && tsc --noEmit"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "^0.65.0",
    "@mariozechner/pi-coding-agent": "^0.65.0",
    "@mariozechner/pi-tui": "^0.65.0",
    "@sinclair/typebox": "^0.34.41",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.1"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "packageManager": "pnpm@10.33.0",
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ]
  }
}
